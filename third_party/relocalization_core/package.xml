<?xml version="1.0"?>
<package format="3">
  <name>relocalization_core</name>
  <version>0.1.0</version>
  <description>Portable point-cloud relocalization core library with NDT and ICP backends.</description>
  <maintainer email="yangxuan@example.com">yangxuan</maintainer>
  <license>Apache-2.0</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <build_depend>libpcl-all-dev</build_depend>
  <build_depend>ndt_omp_ros2</build_depend>

  <build_export_depend>libpcl-all-dev</build_export_depend>
  <build_export_depend>ndt_omp_ros2</build_export_depend>

  <exec_depend>libpcl-all-dev</exec_depend>
  <exec_depend>ndt_omp_ros2</exec_depend>

  <test_depend>ament_cmake_gtest</test_depend>
  <test_depend>ament_lint_auto</test_depend>
  <test_depend>ament_lint_common</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
